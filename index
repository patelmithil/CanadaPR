  const tools = [
    {ic:'📊',name:'CRS Score Calculator',desc:'Estimate your Comprehensive Ranking System score for Express Entry.',
     io:'<strong>Input:</strong> Age, education, language scores, work experience, spouse details, job offer, nomination status.<br><strong>Output:</strong> CRS score out of 1,200 with category breakdown and comparison to recent draws.',
     link:'https://www.cic.gc.ca/english/immigrate/skilled/crs-tool.asp',linkText:'Use IRCC\'s Official CRS Tool →'},
    {ic:'✅',name:'Eligibility Quiz',desc:'Answer simple questions to find which PR programs you may qualify for.',
     io:'<strong>Input:</strong> Nationality, age, education, language ability, work experience, family in Canada, net worth.<br><strong>Output:</strong> Personalized list of eligible PR pathways ranked by likelihood.',
     link:'https://www.canada.ca/en/immigration-refugees-citizenship/services/come-canada-tool.html',linkText:'Try IRCC\'s Come to Canada Tool →'},
    {ic:'📋',name:'Document Checklist Generator',desc:'Get a customized list of every document needed for your specific application.',
     io:'<strong>Input:</strong> Program, country of residence, family members, education location.<br><strong>Output:</strong> Complete checklist with document names, format requirements, and tips.',
     link:'https://www.canada.ca/en/immigration-refugees-citizenship/services/application/application-forms-guides.html',linkText:'IRCC Application Forms & Guides →'},
    {ic:'🔍',name:'NOC Code Finder',desc:'Find the correct National Occupational Classification code for your job.',
     io:'<strong>Input:</strong> Job title, main duties, industry.<br><strong>Output:</strong> Matching NOC codes with TEER level and which PR programs accept that occupation.',
     link:'https://www.canada.ca/en/immigration-refugees-citizenship/services/immigrate-canada/express-entry/eligibility/find-national-occupation-code.html',linkText:'Use IRCC\'s NOC Tool →'},
    {ic:'⏱️',name:'Processing Time Tracker',desc:'Check current estimated processing times for any immigration application.',
     io:'<strong>Input:</strong> Application type, country of residence.<br><strong>Output:</strong> Current IRCC processing time estimate.',
     link:'https://www.canada.ca/en/immigration-refugees-citizenship/services/application/check-processing-times.html',linkText:'Check IRCC Processing Times →'}
  ];
  return `<div class="fade">
  <div class="pg-hdr">
    <a class="back" onclick="go('home')">← Home</a>
    <h1>🛠️ Tools & Resources</h1>
    <p>Official tools to assess eligibility, estimate scores, and prepare your application.</p>
  </div>
  <div class="tool-grid">
    ${tools.map(t => `<div class="tool-card">
      <span class="ic">${t.ic}</span>
      <h3>${t.name}</h3>
      <p>${t.desc}</p>
      <div class="io">${t.io}</div>
      ${t.link ? `<a class="link-btn" href="${t.link}" target="_blank" rel="noopener" style="margin-top:14px">${t.linkText}</a>` : ''}
    </div>`).join('')}
  </div>
  <div class="ftr">All tools link to official IRCC resources. <a href="https://www.canada.ca/en/immigration-refugees-citizenship.html" target="_blank">canada.ca/immigration</a></div>
  </div>`;
}

// ============ SEARCH ============
const searchIndex = [];
Object.keys(P).forEach(catId => {
  const cat = P[catId];
  cat.programs.forEach(p => {
    searchIndex.push({title:p.name,cat:cat.title,page:catId,id:p.id});
    if (p.streams) p.streams.forEach(s => {
      searchIndex.push({title:s[0],cat:cat.title + ' → ' + p.name,page:catId,id:p.id});
    });
  });
});
searchIndex.push({title:'Canadian PR Pathway Finder',cat:'Interactive Tool',page:'_ext',id:'finder'});
[{t:'FAQ — CRS Score',p:'faq'},{t:'FAQ — Express Entry Draws',p:'faq'},{t:'FAQ — Processing Times',p:'faq'},{t:'FAQ — Biometrics',p:'faq'},{t:'FAQ — Settlement Funds',p:'faq'},{t:'FAQ — Citizenship',p:'faq'},
 {t:'CRS Calculator',p:'tools'},{t:'Eligibility Quiz',p:'tools'},{t:'NOC Code Finder',p:'tools'},{t:'Document Checklist',p:'tools'},{t:'Processing Time Tracker',p:'tools'}
].forEach(x => searchIndex.push({title:x.t,cat:x.p==='faq'?'FAQ':'Tools',page:x.p}));

function doSearch(q, input) {
  const isHero = input.id === 'heroSearchInput';
  const dropId = isHero ? 'heroDrop' : 'hdrDrop';
  const drop = document.getElementById(dropId);
  if (!q.trim()) { drop.classList.remove('open'); return; }
  const lq = q.toLowerCase();
  const matches = searchIndex.filter(s => s.title.toLowerCase().includes(lq) || s.cat.toLowerCase().includes(lq));
  if (!matches.length) {
    drop.innerHTML = '<div class="s-item"><h4>No results found</h4></div>';
  } else {
    drop.innerHTML = matches.slice(0, 8).map(m => {
      if (m.page === '_ext') {
        return `<div class="s-item" onclick="window.open('https://019d2059-77a8-79f9-96bc-5da6dff9fb4a.arena.site/','_blank')" style="background:#fef2f2">
          <h4 style="color:#dc2626">🍁 ${m.title}</h4><p>${m.cat}</p>
        </div>`;
      }
      return `<div class="s-item" onclick="go('${m.page}');document.querySelectorAll('.s-drop').forEach(d=>d.classList.remove('open'))">
        <h4>${m.title}</h4><p>${m.cat}</p>
      </div>`;
    }).join('');
  }
  drop.classList.add('open');
}
document.addEventListener('click', e => {
  if (!e.target.closest('.hero-search') && !e.target.closest('.hdr-search'))
    document.querySelectorAll('.s-drop').forEach(d => d.classList.remove('open'));
});

// ============ NAV ============
function updateNav() {
  const dn = document.getElementById('deskNav');
  dn.innerHTML = NAV.filter(n => ['home','express-entry','pnp','family','faq','tools'].includes(n.id))
    .map(n => `<a onclick="go('${n.id}')" class="${currentPage===n.id?'on':''}">${n.label}</a>`).join('');

  const mn = document.getElementById('mobileNav');
  mn.innerHTML = NAV.map(n => `<a onclick="go('${n.id}')">${n.label}</a>`).join('') +
    '<div class="sep"></div>' +
    '<a href="https://019d2059-77a8-79f9-96bc-5da6dff9fb4a.arena.site/" target="_blank" style="color:#dc2626;font-weight:700">🍁 PR Pathway Finder ↗</a>' +
    '<a href="https://www.canada.ca/en/immigration-refugees-citizenship.html" target="_blank">Official IRCC Website ↗</a>';
}

function openNav() { document.getElementById('overlay').classList.add('open'); }
function closeNav() { document.getElementById('overlay').classList.remove('open'); }

// ============ SCROLL ============
window.addEventListener('scroll', () => {
  document.getElementById('scrollBtn').classList.toggle('show', window.scrollY > 300);
});

// ============ HASH ROUTING ============
function handleHash() {
  const hash = window.location.hash.replace('#/', '') || 'home';
  currentPage = hash;
  render();
  updateNav();
}
window.addEventListener('hashchange', handleHash);
handleHash();
</script>
</body>
</html>
