<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CanadaPR — Complete Immigration Guide</title>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#f8f9fb;--card:#fff;--text:#111827;--sub:#64748b;
  --border:#e5e7eb;--accent:#dc2626;--blue:#2563eb;
  --green:#059669;--amber:#d97706;--red:#dc2626;
  --radius:14px;--shadow:0 1px 3px rgba(0,0,0,.06);
  --shadow2:0 8px 30px rgba(0,0,0,.08);
  --max:880px;--font:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
  --ease:cubic-bezier(.4,0,.2,1)
}
html{scroll-behavior:smooth}
body{font-family:var(--font);background:var(--bg);color:var(--text);line-height:1.7;font-size:15px;-webkit-font-smoothing:antialiased}

.hdr{position:sticky;top:0;z-index:100;background:rgba(255,255,255,.92);backdrop-filter:blur(12px);border-bottom:1px solid var(--border)}
.hdr-in{max-width:var(--max);margin:0 auto;display:flex;align-items:center;padding:0 20px;height:56px;gap:12px}
.brand{font-weight:800;font-size:1.1rem;color:var(--accent);text-decoration:none;white-space:nowrap;cursor:pointer}
.brand span{color:var(--text)}
.hdr-search{flex:1;position:relative;max-width:360px;margin-left:auto}
.hdr-search input{width:100%;padding:8px 14px 8px 36px;border:1.5px solid var(--border);border-radius:10px;font-size:.88rem;outline:none;background:var(--bg);transition:border .2s}
.hdr-search input:focus{border-color:var(--blue)}
.hdr-search .si{position:absolute;left:11px;top:50%;transform:translateY(-50%);font-size:.9rem;opacity:.4}
.s-drop{position:absolute;top:calc(100% + 6px);left:0;right:0;background:#fff;border-radius:12px;box-shadow:var(--shadow2);max-height:360px;overflow-y:auto;display:none;z-index:200}
.s-drop.open{display:block}
.s-item{padding:12px 16px;cursor:pointer;border-bottom:1px solid var(--border);transition:background .15s}
.s-item:last-child{border:none}
.s-item:hover{background:#f1f5f9}
.s-item h4{font-size:.9rem;font-weight:600}.s-item p{font-size:.75rem;color:var(--sub)}
.menu-btn{display:none;background:none;border:none;font-size:1.4rem;cursor:pointer;padding:4px 8px;color:var(--text)}
@media(max-width:640px){
  .menu-btn{display:block}
  .hdr-search{max-width:none;margin:0}
  .desk-nav{display:none!important}
}
.desk-nav{display:flex;gap:2px;margin-left:16px}
.desk-nav a{font-size:.82rem;font-weight:500;color:var(--sub);text-decoration:none;padding:6px 12px;border-radius:8px;cursor:pointer;white-space:nowrap;transition:all .15s}
.desk-nav a:hover,.desk-nav a.on{background:#f1f5f9;color:var(--text)}

.overlay{position:fixed;inset:0;z-index:500;display:none;align-items:flex-start;justify-content:flex-end}
.overlay.open{display:flex}
.overlay-bg{position:absolute;inset:0;background:rgba(0,0,0,.3);animation:fadeIn .2s}
.nav-panel{position:relative;z-index:1;width:280px;height:100%;background:#fff;padding:20px;overflow-y:auto;animation:slideIn .25s var(--ease)}
@keyframes slideIn{from{transform:translateX(100%)}to{transform:translateX(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.nav-panel .close{background:none;border:none;font-size:1.4rem;cursor:pointer;float:right;color:var(--sub)}
.nav-panel nav{margin-top:40px;display:flex;flex-direction:column;gap:2px}
.nav-panel nav a{font-size:.95rem;font-weight:500;padding:12px 16px;border-radius:10px;text-decoration:none;color:var(--text);cursor:pointer;transition:background .15s}
.nav-panel nav a:hover{background:#f1f5f9}
.nav-panel nav .sep{height:1px;background:var(--border);margin:8px 0}

main{max-width:var(--max);margin:0 auto;padding:20px;min-height:80vh}
.fade{animation:fadeUp .35s var(--ease)}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}

.hero{text-align:center;padding:48px 0 40px}
.hero h1{font-size:clamp(1.7rem,5vw,2.6rem);font-weight:800;line-height:1.2;margin-bottom:12px;letter-spacing:-.02em}
.hero h1 em{color:var(--accent);font-style:normal}
.hero p{color:var(--sub);font-size:1.05rem;max-width:520px;margin:0 auto 28px}
.hero-search{position:relative;max-width:480px;margin:0 auto}
.hero-search input{width:100%;padding:14px 18px 14px 44px;border:2px solid var(--border);border-radius:50px;font-size:.95rem;outline:none;transition:border .2s;background:#fff}
.hero-search input:focus{border-color:var(--blue)}
.hero-search .si{position:absolute;left:16px;top:50%;transform:translateY(-50%);font-size:1rem;opacity:.35}
.hero-search .s-drop{border-radius:16px}

.sec-title{font-size:1.2rem;font-weight:700;margin:36px 0 6px}
.sec-sub{color:var(--sub);font-size:.9rem;margin-bottom:20px}
.cat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:14px;margin-bottom:48px}
.cat-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:22px 20px;cursor:pointer;transition:all .2s;text-decoration:none;color:inherit}
.cat-card:hover{box-shadow:var(--shadow2);transform:translateY(-2px);border-color:#d1d5db}
.cat-card .ic{font-size:1.6rem;margin-bottom:8px;display:block}
.cat-card h3{font-size:.98rem;font-weight:700;margin-bottom:4px}
.cat-card p{color:var(--sub);font-size:.82rem;line-height:1.5}

/* ===== FEATURED CTA CARD ===== */
.cat-card.featured{
  background:linear-gradient(135deg,#dc2626 0%,#b91c1c 100%);
  border:2px solid #dc2626;
  color:#fff;
  position:relative;
  overflow:hidden;
  grid-column:1 / -1;
}
.cat-card.featured::before{
  content:'';
  position:absolute;
  top:-50%;right:-50%;width:200%;height:200%;
  background:radial-gradient(circle,rgba(255,255,255,.08) 0%,transparent 60%);
  animation:shimmer 3s ease-in-out infinite;
}
@keyframes shimmer{
  0%,100%{transform:translate(0,0)}
  50%{transform:translate(-5%,5%)}
}
.cat-card.featured:hover{
  box-shadow:0 12px 40px rgba(220,38,38,.3);
  transform:translateY(-3px);
  border-color:#ef4444;
  background:linear-gradient(135deg,#ef4444 0%,#dc2626 100%);
}
.cat-card.featured .ic{font-size:2rem}
.cat-card.featured h3{font-size:1.15rem;color:#fff}
.cat-card.featured p{color:rgba(255,255,255,.85);font-size:.88rem}
.cat-card.featured .cta-arrow{
  display:inline-flex;align-items:center;gap:6px;
  margin-top:10px;
  font-size:.82rem;font-weight:700;
  color:#fff;
  background:rgba(255,255,255,.18);
  padding:8px 18px;
  border-radius:50px;
  transition:background .2s;
}
.cat-card.featured:hover .cta-arrow{background:rgba(255,255,255,.28)}
.maple-leaf{
  position:absolute;
  bottom:12px;right:16px;
  font-size:3.5rem;
  opacity:.12;
  pointer-events:none;
}

.pg-hdr{margin-bottom:24px;padding-bottom:20px;border-bottom:1px solid var(--border)}
.pg-hdr .back{font-size:.85rem;color:var(--blue);cursor:pointer;display:inline-flex;align-items:center;gap:4px;margin-bottom:8px;font-weight:500;text-decoration:none}
.pg-hdr .back:hover{text-decoration:underline}
.pg-hdr h1{font-size:1.6rem;font-weight:800;line-height:1.3}
.pg-hdr p{color:var(--sub);font-size:.93rem;margin-top:6px}

.p-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);margin-bottom:12px;overflow:hidden;box-shadow:var(--shadow);transition:box-shadow .2s}
.p-card:hover{box-shadow:var(--shadow2)}
.p-head{padding:16px 20px;cursor:pointer;display:flex;align-items:center;gap:12px;transition:background .15s}
.p-head:hover{background:#fafbfc}
.p-head h2{font-size:.95rem;font-weight:600;flex:1;line-height:1.4}
.badge{font-size:.7rem;font-weight:700;padding:3px 10px;border-radius:50px;white-space:nowrap;flex-shrink:0;letter-spacing:.02em}
.badge.active{background:#ecfdf5;color:var(--green)}
.badge.paused{background:#fffbeb;color:var(--amber)}
.badge.closed{background:#fef2f2;color:var(--red)}
.arrow{font-size:.7rem;color:var(--sub);transition:transform .25s;flex-shrink:0}
.p-card.open .arrow{transform:rotate(180deg)}
.p-body{max-height:0;overflow:hidden;transition:max-height .4s var(--ease);padding:0 20px}
.p-card.open .p-body{max-height:3000px;padding:0 20px 20px}

.sumbox{background:#eff6ff;border-left:3px solid var(--blue);padding:14px 16px;border-radius:0 10px 10px 0;margin:12px 0 16px;font-size:.88rem;line-height:1.6}
.sumbox strong{display:block;font-size:.72rem;color:var(--blue);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px}

.info-row{display:flex;flex-wrap:wrap;gap:10px;margin:14px 0}
.info-pill{background:#f1f5f9;padding:10px 14px;border-radius:10px;flex:1;min-width:140px}
.info-pill .l{font-size:.68rem;color:var(--sub);text-transform:uppercase;letter-spacing:.4px;margin-bottom:2px}
.info-pill .v{font-weight:700;font-size:.9rem}

.p-body h3{font-size:.88rem;font-weight:700;margin:16px 0 8px;color:var(--text)}
.p-body ul{margin-left:18px;margin-bottom:10px}
.p-body li{font-size:.86rem;color:#374151;margin-bottom:5px;line-height:1.6}
.p-body table{width:100%;border-collapse:collapse;margin:10px 0;font-size:.84rem}
.p-body th,.p-body td{text-align:left;padding:8px 12px;border-bottom:1px solid var(--border)}
.p-body th{background:#f8fafc;font-weight:600;font-size:.72rem;text-transform:uppercase;letter-spacing:.3px;color:var(--sub)}

.link-btn{display:inline-block;margin-top:14px;padding:9px 20px;background:var(--accent);color:#fff;text-decoration:none;border-radius:9px;font-weight:600;font-size:.82rem;transition:background .2s}
.link-btn:hover{background:#b91c1c}
.upd-flag{display:inline-block;font-size:.68rem;color:var(--amber);background:#fffbeb;padding:2px 8px;border-radius:50px;font-weight:600;margin-left:6px}
.closed-msg{color:var(--red);font-weight:600;font-size:.9rem;padding:8px 0}

.faq{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);margin-bottom:10px;overflow:hidden}
.faq-q{padding:16px 20px;font-weight:600;font-size:.9rem;cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:12px;transition:background .15s}
.faq-q:hover{background:#fafbfc}
.faq-a{max-height:0;overflow:hidden;transition:max-height .35s var(--ease);padding:0 20px;font-size:.88rem;color:#374151;line-height:1.8}
.faq.open .faq-a{max-height:800px;padding:0 20px 16px}
.faq.open .faq-toggle{transform:rotate(180deg)}
.faq-toggle{transition:transform .25s;color:var(--sub);font-size:.7rem;flex-shrink:0}

.tool-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:16px;margin:24px 0 48px}
.tool-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:24px;box-shadow:var(--shadow)}
.tool-card .ic{font-size:1.6rem;margin-bottom:10px;display:block}
.tool-card h3{font-size:1rem;font-weight:700;margin-bottom:6px}
.tool-card p{color:var(--sub);font-size:.86rem;margin-bottom:6px}
.io{background:#f8fafc;border-radius:10px;padding:12px 14px;margin-top:10px;font-size:.82rem;line-height:1.7}
.io strong{color:var(--blue)}

.ftr{text-align:center;padding:36px 20px;font-size:.78rem;color:var(--sub);border-top:1px solid var(--border);margin-top:48px;line-height:2}
.ftr a{color:var(--blue)}

.scroll-btn{position:fixed;bottom:20px;right:20px;width:42px;height:42px;border-radius:50%;background:var(--text);color:#fff;border:none;font-size:1.1rem;cursor:pointer;box-shadow:var(--shadow2);opacity:0;pointer-events:none;transition:all .25s;z-index:90;display:flex;align-items:center;justify-content:center}
.scroll-btn.show{opacity:1;pointer-events:auto}
.scroll-btn:hover{transform:scale(1.1)}

@media(max-width:640px){
  main{padding:16px}
  .cat-grid{grid-template-columns:1fr}
  .cat-card.featured{grid-column:auto}
  .tool-grid{grid-template-columns:1fr}
  .info-row{flex-direction:column}
  .hero{padding:36px 0 28px}
  .p-head{padding:14px 16px}
  .p-body{padding:0 16px}
  .p-card.open .p-body{padding:0 16px 16px}
}
</style>
</head>
<body>

<header class="hdr">
  <div class="hdr-in">
    <a class="brand" onclick="go('home')">🍁 <span>CanadaPR</span></a>
    <div class="hdr-search" id="hdrSearch" style="display:none">
      <span class="si">🔍</span>
      <input type="text" placeholder="Search programs…" oninput="doSearch(this.value,this)" autocomplete="off">
      <div class="s-drop" id="hdrDrop"></div>
    </div>
    <nav class="desk-nav" id="deskNav"></nav>
    <button class="menu-btn" onclick="openNav()">☰</button>
  </div>
</header>

<div class="overlay" id="overlay">
  <div class="overlay-bg" onclick="closeNav()"></div>
  <div class="nav-panel">
    <button class="close" onclick="closeNav()">✕</button>
    <nav id="mobileNav"></nav>
  </div>
</div>

<main id="app"></main>
<button class="scroll-btn" id="scrollBtn" onclick="window.scrollTo({top:0,behavior:'smooth'})">↑</button>

<script>
const CATS = [
  {id:'express-entry',name:'Express Entry',icon:'⚡',desc:'Canada\'s fastest PR system — FSWP, CEC, FSTP, and category-based draws.'},
  {id:'pnp',name:'Provincial Nominees',icon:'🏛️',desc:'Over 80 streams across provinces and territories targeting local labor needs.'},
  {id:'family',name:'Family Sponsorship',icon:'👨‍👩‍👧‍👦',desc:'Sponsor your spouse, children, parents, or grandparents for PR.'},
  {id:'quebec',name:'Quebec Programs',icon:'⚜️',desc:'Quebec runs its own immigration system — separate from federal programs.'},
  {id:'pilots',name:'Regional & Pilot',icon:'🌾',desc:'Atlantic Immigration, RNIP, Francophone, and targeted community programs.'},
  {id:'trtopr',name:'TR → PR',icon:'🔄',desc:'Pathways for people already in Canada on work or study permits.'},
  {id:'business',name:'Business & Investor',icon:'💼',desc:'Start-Up Visa, Self-Employed, and provincial business streams.'},
  {id:'humanitarian',name:'Humanitarian',icon:'🕊️',desc:'Refugee protection, H&C grounds, caregiver pilots, and public policy programs.'}
];

const NAV = [{id:'home',label:'Home'},...CATS.map(c=>({id:c.id,label:c.name})),{id:'faq',label:'FAQ'},{id:'tools',label:'Tools'}];

const P = {
'express-entry':{
  title:'Express Entry',icon:'⚡',
  desc:'Canada\'s flagship points-based immigration system. Manages three federal economic programs through the Comprehensive Ranking System (CRS). Most applications processed in about 6 months.',
  programs:[
    {id:'fswp',name:'Federal Skilled Worker Program (FSWP)',status:'active',
     summary:'For skilled workers with foreign work experience. You need at least 1 year of skilled work experience, strong language scores, and 67+ points on a selection grid. You then enter the Express Entry pool and are ranked by CRS.',
     eligibility:['1+ year continuous full-time skilled work experience (NOC TEER 0, 1, 2, or 3) in the last 10 years','Language: minimum CLB 7 in all four abilities','Educational Credential Assessment (ECA) for foreign education','Score 67+ on the FSWP selection grid (language, education, experience, age, job offer, adaptability)','Proof of settlement funds (unless you have a valid Canadian job offer)','Be admissible to Canada (no criminal or medical inadmissibility)'],
     documents:['Valid passport','IELTS General or CELPIP (English) / TEF or TCF (French) results','ECA report from a designated organization','Work experience proof (reference letters, pay stubs, contracts)','Proof of funds (bank statements)','Police clearance certificates from every country lived in 6+ months since age 18','Medical exam from an IRCC panel physician','Digital photos meeting IRCC specifications'],
     processingTime:'~6 months after ITA',fees:'$850 processing + $515 RPRF = $1,365 per adult. Spouse: $1,365. Child: $230. Biometrics: $85/person.',
     link:'https://www.canada.ca/en/immigration-refugees-citizenship/services/immigrate-canada/express-entry/eligibility/federal-skilled-workers.html'},
    {id:'cec',name:'Canadian Experience Class (CEC)',status:'active',
     summary:'For people who have already worked in Canada. If you have 1+ year of skilled Canadian work experience in the last 3 years, this may be your fastest path. No education requirement and no points grid — meet the minimums and enter the Express Entry pool.',
     eligibility:['12+ months full-time (or equivalent part-time) skilled Canadian work experience in the last 3 years','Work must be NOC TEER 0, 1, 2, or 3','Language: CLB 7 for TEER 0/1; CLB 5 for TEER 2/3','Experience must have been authorized work in Canada','Must not have been a full-time student during the claimed work period','Plan to live outside Quebec'],
     documents:['Valid passport','Language test results','Canadian work proof (T4 slips, reference letters, pay stubs, ROE)','Police clearance certificates','Medical exam results','ECA report (optional but boosts CRS score)'],
     processingTime:'~6 months after ITA',fees:'$1,365 per adult (same as FSWP)',
     link:'https://www.canada.ca/en/immigration-refugees-citizenship/services/immigrate-canada/express-entry/eligibility/canadian-experience-class.html'},
    {id:'fstp',name:'Federal Skilled Trades Program (FSTP)',status:'active',
     summary:'For skilled tradespeople — electricians, plumbers, welders, heavy equipment operators, cooks, and similar roles. You need 2 years of trade experience, plus either a valid Canadian job offer or a Canadian trade certificate. No education requirement.',
     eligibility:['2+ years full-time skilled trade experience in the last 5 years','Qualifying trades in NOC TEER 2 or 3 (industrial, electrical, construction, maintenance, agriculture, food processing)','Valid job offer of 1+ year from up to 2 Canadian employers, OR a certificate of qualification from a Canadian province/territory','Language: CLB 5 speaking/listening, CLB 4 reading/writing','No minimum education requirement'],
     documents:['Valid passport','Language test results','Trade work experience proof with detailed job duty descriptions','Certificate of qualification or job offer letter(s)','Police clearance certificates','Medical exam results'],
     processingTime:'~6 months after ITA',fees:'$1,365 per adult',
     link:'https://www.canada.ca/en/immigration-refugees-citizenship/services/immigrate-canada/express-entry/eligibility/skilled-trades.html'},
    {id:'catdraws',name:'Category-Based Selection Draws',status:'active',flag:'Since 2023',
     summary:'Since 2023, IRCC issues Express Entry invitations targeting specific categories — healthcare, STEM, trades, transport, agriculture, and French-language speakers. You still need an Express Entry profile, but targeted draws may invite you at a lower CRS than general draws.',
     eligibility:['Must have a valid Express Entry profile (FSWP, CEC, or FSTP eligible)','Must have work experience or qualifications in the target category','Categories announced so far: Healthcare, STEM, Trades, Transport, Agriculture & agri-food, French-language proficiency'],
     documents:['Same as the underlying EE program (FSWP, CEC, or FSTP)'],
     processingTime:'~6 months after ITA',fees:'Same as Express Entry',
     link:'https://www.canada.ca/en/immigration-refugees-citizenship/services/immigrate-canada/express-entry/submit-profile/rounds-invitations.html',
     note:'Categories and CRS cutoffs change with every draw. Always check the official Rounds of Invitations page for the latest results.'}
  ]
},
'pnp':{
  title:'Provincial Nominee Programs (PNPs)',icon:'🏛️',
  desc:'Each province and territory (except Nunavut and Quebec) nominates immigrants who meet local economic needs. A provincial nomination adds 600 CRS points in Express Entry or allows a paper-based application. Processing: typically 1–6 months at the provincial level, then 6+ months federally.',
  programs:[
    {id:'oinp',name:'Ontario — OINP',status:'active',
     summary:'Canada\'s most populous province. Multiple EE-linked and base streams. Uses an Expression of Interest (EOI) system with periodic draws.',
     streams:[['Human Capital Priorities','EE','✅'],['French-Speaking Skilled Worker','EE','✅'],['Skilled Trades','EE','✅'],['Employer Job Offer: Foreign Worker','Base','✅'],['Employer Job Offer: International Student','Base','✅'],['Employer Job Offer: In-Demand Skills','Base','✅'],['Masters Graduate','Base','✅'],['PhD Graduate','Base','✅']],
     fees:'$1,500 provincial + federal fees',
     link:'https://www.ontario.ca/page/ontario-immigrant-nominee-program-oinp'},
    {id:'bcpnp',name:'British Columbia — BC PNP',status:'active',
     summary:'Uses a Skills Immigration Registration System (SIRS) with regular draws. Both Express Entry and direct streams are available for skilled workers, healthcare professionals, and graduates.',
     streams:[['Skilled Worker','SI / EE','✅'],['Healthcare Professional','SI / EE','✅'],['International Graduate','SI / EE','✅'],['International Post-Graduate','SI / EE','✅'],['Entry Level and Semi-Skilled','SI','✅'],['Entrepreneur — Base','Business','✅'],['Entrepreneur — Regional Pilot','Business','✅']],
     fees:'$1,150 provincial + federal fees',
     link:'https://www.welcomebc.ca/Immigrate-to-B-C/About-The-BC-PNP'},
    {id:'aaip',name:'Alberta — AAIP',status:'active',
     summary:'Alberta\'s rebranded immigration program includes EE and non-EE streams for workers and entrepreneurs. Uses EOI draws targeting specific occupations.',
     streams:[['Alberta Express Entry Stream','EE','✅'],['Alberta Opportunity Stream','Base','✅'],['Rural Renewal Stream','Base','✅'],['Rural Entrepreneur Stream','Business','✅'],['Graduate Entrepreneur Stream','Business','✅'],['Farm Stream','Base','✅'],['Tourism & Hospitality Stream','Base','✅']],
     fees:'$500 provincial + federal fees',
     link:'https://www.alberta.ca/alberta-advantage-immigration-program'},
    {id:'sinp',name:'Saskatchewan — SINP',status:'active',
     summary:'Uses an EOI system with regular draws. Popular for its Occupation In-Demand and Express Entry sub-categories.',
     streams:[['International Skilled Worker — Employment Offer','Base','✅'],['International Skilled Worker — Occupation In-Demand','Base','✅'],['International Skilled Worker — Saskatchewan EE','EE','✅'],['Saskatchewan Experience — Existing Work Permit','Base','✅'],['Saskatchewan Experience — Health Professionals','Base','✅'],['Saskatchewan Experience — Hospitality','Base','✅'],['Saskatchewan Experience — Students','Base','✅'],['Entrepreneur & Farm','Business','✅'],['International Graduate Entrepreneur','Business','✅']],
     fees:'$350 provincial + federal fees',
     link:'https://www.saskatchewan.ca/residents/moving-to-saskatchewan/live-in-saskatchewan/by-immigrating/saskatchewan-immigrant-nominee-program'},
    {id:'mpnp',name:'Manitoba — MPNP',status:'active',
     summary:'One of Canada\'s most established PNPs. Prioritizes candidates with connections to Manitoba through family, work, or education in the province.',
     streams:[['Skilled Worker in Manitoba','Base','✅'],['Skilled Worker Overseas','Base','✅'],['International Education Stream','Base','✅'],['Business Investor Stream','Business','✅'],['Human Capital Pathway','EE','✅']],
     fees:'$500 provincial + federal fees',
     link:'https://immigratemanitoba.com/'},
