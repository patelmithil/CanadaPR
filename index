const FAQS = [
  {q:'What is the difference between Express Entry and a PNP?',a:'Express Entry is a federal system managing three programs (FSWP, CEC, FSTP) using the CRS points system. A PNP is run by an individual province to nominate immigrants meeting local needs. They often work together — a provincial nomination adds 600 CRS points, virtually guaranteeing an invitation. You can also apply through non-Express Entry PNP streams processed separately.'},
  {q:'What is a CRS score and what is a "good" score?',a:'The Comprehensive Ranking System scores your Express Entry profile out of 1,200 points based on age, education, language, work experience, and other factors. General draw cutoffs typically range from 430 to 530+, but change every draw. Category-based draws may have lower cutoffs. A provincial nomination adds 600 points. There is no fixed "good" score — check the latest draw results on the IRCC website.'},
  {q:'How often does Canada hold Express Entry draws?',a:'IRCC typically holds draws every 1–2 weeks, but schedules vary. Since 2023, category-based draws target specific occupations or French-language speakers alongside general draws. Schedules are not published in advance — check the official Rounds of Invitations page.'},
  {q:'Do I need a job offer to apply for PR?',a:'Not necessarily. Most Express Entry candidates don\'t have job offers. However, a valid LMIA-supported job offer adds 50 or 200 CRS points. Some programs (AIP, some PNP streams) do require a job offer. Each pathway has different requirements.'},
  {q:'What language tests are accepted?',a:'English: IELTS General Training or CELPIP General. French: TEF Canada or TCF Canada. Academic IELTS is NOT accepted. Results are valid for 2 years. You can test in both languages to maximize CRS points.'},
  {q:'What is an Educational Credential Assessment (ECA)?',a:'An ECA verifies that your foreign education equals a Canadian credential. Required for Express Entry if your education was outside Canada. Designated organizations: WES, IQAS, CES, ICAS, and others. Valid for 5 years. Processing takes 4–8 weeks.'},
  {q:'What are biometrics?',a:'Fingerprints and photograph. Most PR applicants ages 14–79 must provide them. After submitting your application, IRCC sends a biometrics instruction letter. Visit a designated collection point. Fee: $85/person or $170/family. Valid for 10 years.'},
  {q:'How long does PR processing take?',a:'Express Entry: ~6 months after ITA. PNP (non-EE): 15–19 months. Spousal sponsorship: ~12 months. Parents/grandparents: 20–24 months. Business programs: 12–36+ months. Check the IRCC processing times tool for current estimates.'},
  {q:'Can I include my family in my PR application?',a:'Yes. Most programs allow you to include your spouse/common-law partner and dependent children (under 22, unmarried). They receive PR when your application is approved. You must declare all family members even if not accompanying you.'},
  {q:'What happens after I get PR status?',a:'You receive a Confirmation of Permanent Residence (COPR). If outside Canada, complete landing at a port of entry. Your PR card is mailed to your Canadian address (1–3 months). You can live, work, study anywhere in Canada. Maintain PR by being physically present 730+ days in every 5-year period.'},
  {q:'How long to get a PR card?',a:'First PR card after landing: 1–3 months by mail. Renewals: 49–97 days. PR card is valid for 5 years. You need it to re-enter Canada if travelling abroad.'},
  {q:'When can I apply for Canadian citizenship?',a:'After 1,095 days (3 years) of physical presence in Canada within the 5 years before applying. Must also meet language requirements (CLB 4+, ages 18–54), pass a citizenship test, file Canadian taxes, and have no criminal/removal issues.'},
  {q:'What are NOC and TEER?',a:'NOC = National Occupational Classification — Canada\'s job categorization system. TEER = Training, Education, Experience, Responsibilities — levels 0–5, replacing the old A/B/C/D in 2022. Most PR programs require TEER 0–3 ("skilled"). Use the NOC search tool at canada.ca.'},
  {q:'Can I apply to multiple PR programs at once?',a:'You can have an Express Entry profile while applying to PNP streams separately. Don\'t submit multiple federal PR applications simultaneously. If you get a provincial nomination, add it to your Express Entry profile.'},
  {q:'Do I need an immigration consultant?',a:'No — you can apply on your own using IRCC\'s guides. For complex cases, use a licensed RCIC (Regulated Canadian Immigration Consultant) or Canadian lawyer. Unlicensed "ghost agents" are illegal.'},
  {q:'What are the settlement fund requirements?',a:'Approx. 2024: 1 person ~$14,690; 2 ~$18,288; 3 ~$22,483; 4 ~$27,297. Not required if you have a valid job offer or applying through CEC while working in Canada. Check IRCC for current amounts.'}
];

// ============ ROUTER & RENDER ============
let currentPage = 'home';

function go(page) {
  currentPage = page;
  window.location.hash = '#/' + page;
  render();
  window.scrollTo({top:0,behavior:'smooth'});
  closeNav();
  updateNav();
}

function render() {
  const app = document.getElementById('app');
  const s = document.getElementById('hdrSearch');
  s.style.display = currentPage === 'home' ? 'none' : 'block';

  if (currentPage === 'home') app.innerHTML = renderHome();
  else if (currentPage === 'faq') app.innerHTML = renderFAQ();
  else if (currentPage === 'tools') app.innerHTML = renderTools();
  else if (P[currentPage]) app.innerHTML = renderCategory(currentPage);
  else app.innerHTML = renderHome();
}

function renderHome() {
  const catCards = CATS.map(c => `<div class="cat-card" onclick="go('${c.id}')">
    <span class="ic">${c.icon}</span>
    <h3>${c.name}</h3>
    <p>${c.desc}</p>
  </div>`).join('');

  const featuredCard = `<a class="cat-card featured" href="https://019d2059-77a8-79f9-96bc-5da6dff9fb4a.arena.site/" target="_blank" rel="noopener">
    <span class="ic">🍁</span>
    <h3>Canadian PR Pathway Finder</h3>
    <p>Not sure which program is right for you? Use our interactive Pathway Finder tool to discover your best PR route to Canada — personalized to your profile.</p>
    <span class="cta-arrow">Find Your Pathway →</span>
    <span class="maple-leaf">🍁</span>
  </a>`;

  return `<div class="fade">
  <div class="hero">
    <h1>Your Complete Guide to<br><em>Canadian PR</em></h1>
    <p>Every permanent residence pathway — eligibility, documents, fees, and official links. Plain English. Always current.</p>
    <div class="hero-search" style="position:relative">
      <span class="si">🔍</span>
      <input type="text" placeholder="Search any program, province, or keyword…" oninput="doSearch(this.value,this)" autocomplete="off" id="heroSearchInput">
      <div class="s-drop" id="heroDrop"></div>
    </div>
  </div>
  <h2 class="sec-title">Explore by Category</h2>
  <p class="sec-sub">Select a category to view every available stream.</p>
  <div class="cat-grid">
    ${catCards}
    ${featuredCard}
  </div>
  <div class="ftr">
    <strong>CanadaPR Guide</strong> — Free informational resource. Not affiliated with IRCC or the Government of Canada.<br>
    Not legal advice. Always verify at <a href="https://www.canada.ca/en/immigration-refugees-citizenship.html" target="_blank">canada.ca/immigration</a>.
  </div>
  </div>`;
}

function renderCategory(catId) {
  const cat = P[catId];
  if (!cat) return renderHome();
  return `<div class="fade">
  <div class="pg-hdr">
    <a class="back" onclick="go('home')">← All Categories</a>
    <h1>${cat.icon} ${cat.title}</h1>
    <p>${cat.desc}</p>
  </div>
  ${cat.programs.map(p => renderProgramCard(p, catId)).join('')}
  <div class="ftr">
    <strong>CanadaPR Guide</strong> — Not affiliated with IRCC. Verify at <a href="https://www.canada.ca/en/immigration-refugees-citizenship.html" target="_blank">canada.ca/immigration</a>.
  </div>
  </div>`;
}

function renderProgramCard(p, catId) {
  const statusClass = p.status === 'active' ? 'active' : p.status === 'paused' ? 'paused' : 'closed';
  const statusText = p.status === 'active' ? '✅ Active' : p.status === 'paused' ? '⚠️ Paused' : '❌ Closed';
  const flag = p.flag ? `<span class="upd-flag">${p.flag}</span>` : '';
  const catName = P[catId]?.title || '';

  let body = '';

  if (p.summary) body += `<div class="sumbox"><strong>30-Second Summary</strong>${p.summary}</div>`;

  if (p.status === 'closed' && p.note) body += `<p class="closed-msg">❌ ${p.note}</p>`;

  if (p.eligibility?.length && p.status !== 'closed') {
    const infoItems = [];
    if (catName) infoItems.push({l:'Category',v:catName});
    if (p.processingTime && p.processingTime !== 'N/A') infoItems.push({l:'Processing Time',v:p.processingTime});
    if (p.fees && p.fees !== 'N/A') infoItems.push({l:'Fees (CAD)',v:p.fees});
    if (infoItems.length) body += `<div class="info-row">${infoItems.map(i=>`<div class="info-pill"><div class="l">${i.l}</div><div class="v">${i.v}</div></div>`).join('')}</div>`;
    body += `<h3>Eligibility</h3><ul>${p.eligibility.map(e=>`<li>${e}</li>`).join('')}</ul>`;
  }

  if (p.streams) {
    body += `<h3>Streams</h3><table><tr><th>Stream</th><th>Type</th><th>Status</th></tr>${p.streams.map(s=>`<tr><td>${s[0]}</td><td>${s[1]}</td><td>${s[2]}</td></tr>`).join('')}</table>`;
    if (p.fees) body += `<div class="info-row"><div class="info-pill"><div class="l">Fees</div><div class="v">${p.fees}</div></div></div>`;
  }

  if (p.documents?.length && p.documents[0] !== 'N/A') {
    body += `<h3>Required Documents</h3><ul>${p.documents.map(d=>`<li>${d}</li>`).join('')}</ul>`;
  }

  if (p.note && p.status !== 'closed') body += `<p style="font-size:.82rem;color:var(--amber);margin-top:10px"><em>⚠️ ${p.note}</em></p>`;

  if (p.link) body += `<a class="link-btn" href="${p.link}" target="_blank" rel="noopener">Official Source →</a>`;

  return `<div class="p-card" id="${p.id||''}">
    <div class="p-head" onclick="this.parentElement.classList.toggle('open')">
      <h2>${p.name}${flag}</h2>
      <span class="badge ${statusClass}">${statusText}</span>
      <span class="arrow">▼</span>
    </div>
    <div class="p-body">${body}</div>
  </div>`;
}

function renderFAQ() {
  return `<div class="fade">
  <div class="pg-hdr">
    <a class="back" onclick="go('home')">← Home</a>
    <h1>❓ Frequently Asked Questions</h1>
    <p>Clear answers to common questions about Canadian permanent residence.</p>
  </div>
  ${FAQS.map(f => `<div class="faq">
    <div class="faq-q" onclick="this.parentElement.classList.toggle('open')">
      <span>${f.q}</span><span class="faq-toggle">▼</span>
    </div>
    <div class="faq-a">${f.a}</div>
  </div>`).join('')}
  <div class="ftr">Verify all information at <a href="https://www.canada.ca/en/immigration-refugees-citizenship.html" target="_blank">canada.ca/immigration</a>.</div>
  </div>`;
}

